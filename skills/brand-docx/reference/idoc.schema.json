{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "IntermediateDocument",
  "type": "object",
  "required": ["blocks"],
  "properties": {
    "cover": { "type": "object" },
    "meta": { "type": "object" },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string" }
        }
      }
    }
  }
}
